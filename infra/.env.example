# infra/.env
# 이 파일을 복사해서 infra/.env로 만들고 실제 값을 채운다.
# infra/.env는 .gitignore에 포함 — 절대 커밋 금지.
#
# 강력한 랜덤 비밀번호 생성:
#   openssl rand -base64 32 | tr -d '=+/' | cut -c1-32
# (특수문자 제외 — init-roles.sh의 psql 주입 안전성 확보)

# -----------------------------------------------------------------------------
# Postgres superuser (postgres 계정) 비밀번호
# 운영/마이그레이션/백업 전용. 앱 접속에는 사용 금지.
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# TradingView-1 앱 유저 (trading_app) 비밀번호
# Next.js .env.local의 DATABASE_URL에 이 비밀번호 사용:
#   DATABASE_URL=postgres://trading_app:<이 값>@<host>:5432/trading
# -----------------------------------------------------------------------------
TRADING_APP_PASSWORD=

# -----------------------------------------------------------------------------
# Redis 비밀번호 (TradingView-1 전용 Redis)
#   REDIS_URL=redis://:<이 값>@<host>:6379
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# 포트 바인딩 호스트
# - 127.0.0.1 (기본): 같은 VM에서만 접근. 다른 기기는 SSH 터널 필요
# - 100.x.x.x: VM1의 Tailscale IP — Tailscale 네트워크의 모든 기기에서 접근
# 보안상 0.0.0.0(전체 공개)은 절대 쓰지 말 것.
# -----------------------------------------------------------------------------
DB_BIND_HOST=127.0.0.1
REDIS_BIND_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Phase 2: 대출계산 SaaS 스택 추가 시 아래 주석 해제
# (RUNBOOK.md의 "Phase 2: SaaS 추가 절차" 섹션 참조)
# -----------------------------------------------------------------------------
# LOANAPP_APP_PASSWORD=

# -----------------------------------------------------------------------------
# tv1-web (Next.js 프로덕션 컨테이너)용 환경변수
# .env.local의 동일 값을 여기에도 복사. docker compose가 tv1-web에 주입.
# -----------------------------------------------------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ENV=live
# (선택) 기존 토큰 있으면 채워넣기. 비워두면 앱이 /oauth2/tokenP로 자동 발급.
KIS_ACCESS_TOKEN=
KIS_ACCESS_TOKEN_EXPIRES_AT=

# /api/cron/* 보호용 Bearer 시크릿. `openssl rand -hex 32`로 생성.
CRON_SHARED_SECRET=
